# Plaid Configuration
PLAID_CLIENT_ID=<your_plaid_client_id>
PLAID_SECRET=<your_plaid_secret>
PLAID_ENV=<your_plaid_env> # sandbox, development, or production

# Stripe Configuration
STRIPE_API_KEY=<your_stripe_api_key>
STRIPE_WEBHOOK_SECRET=<your_stripe_webhook_secret>

# Covalent API Key
COVALENT_API_KEY=<your_covalent_api_key>

# Cred Protocol Configuration
CRED_PROTOCOL_API_KEY=<your_cred_protocol_api_key>

# Chainlink Configuration
CHAINLINK_NODE_URL=<your_chainlink_node_url>
CHAINLINK_OPERATOR_ADDRESS=<your_chainlink_operator_address>

# LayerZero Configuration
LAYERZERO_ENDPOINT=<your_layerzero_endpoint>

# IOTA Configuration
IOTA_NODE_URL=<your_iota_node_url>

# Blockchain RPC Endpoints
ETHEREUM_RPC_URL=<your_ethereum_rpc_url>
BINANCE_SMART_CHAIN_RPC_URL=<your_bsc_rpc_url>

# Database Configuration
DB_HOST=<your_db_host>
DB_PORT=<your_db_port>
DB_USER=<your_db_user>
DB_PASSWORD=<your_db_password>
DB_NAME=<your_db_name>

# Redis Configuration
REDIS_HOST=<your_redis_host>
REDIS_PORT=<your_redis_port>

# JWT Secrets
JWT_SECRET=<your_jwt_secret>
JWT_EXPIRATION=<your_jwt_expiration_time> # e.g., 1h, 2h

# API Keys
GENERIC_API_KEY=<your_generic_api_key>
